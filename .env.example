# Optional: connect StudyTime to Supabase (auth + cloud storage for sessions/settings).
# Leave unset to keep the original localStorage + mock auth behavior.
#
# Use the Project URL + **anon** OR **publishable** key only (browser-safe).
# Never put `sb_secret_…` or service_role keys in NEXT_PUBLIC_* — Vercel exposes them to the client.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Option A (classic): JWT anon key from Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_JWT

# Option B (newer dashboard): publishable key — use this OR anon, not both required
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
