# StudyTime environment variables
#
# Copy to `.env.local` and fill in your Supabase project values, then restart
# `npm run dev`. Social features (friends, presence, activity feed, public
# profiles) require Supabase; without it the app runs in local/demo mode.
#
# Supabase → Project Settings → API:

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Use ONE of the following browser-safe keys (never the sb_secret_ key):
#   - anon public (JWT, starts with eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#   - or the publishable key (starts with sb_publishable_...)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Apply migrations in supabase/migrations/ in filename order (SQL Editor or
# `supabase db push`). Enable Realtime for user_presence, notifications, and
# activity_events in Database → Replication.
